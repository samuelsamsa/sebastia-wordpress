# WordPress core — install fresh, not tracked
wp-admin/
wp-includes/
wp-*.php
xmlrpc.php
index.php
license.txt
readme.html

# Environment config — contains DB credentials
wp-config.php

# Uploads — too large for git; share separately
wp-content/uploads/

