wp-content/plugins/

# All themes except the custom one
wp-content/themes/*
!wp-content/themes/sebastia/

# Cache / generated
wp-content/cache/
wp-content/upgrade/
wp-content/backups/

# OS / editor noise
.DS_Store
.DS_Store?
Thumbs.db
.idea/
.vscode/
*.log
node_modules/
